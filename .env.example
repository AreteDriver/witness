# WatchTower Configuration
# Copy to .env and fill in values

# World API — blockchain gateway (confirmed 2026-03-07)
WATCHTOWER_WORLD_API_BASE=https://blockchain-gateway-stillness.live.tech.evefrontier.com

# Polling interval in seconds
WATCHTOWER_POLL_INTERVAL_SECONDS=30

# Database path
WATCHTOWER_DB_PATH=data/watchtower.db

# Discord bot token (from Discord Developer Portal)
WATCHTOWER_DISCORD_TOKEN=

# Default Discord webhook URL for alerts
WATCHTOWER_DISCORD_WEBHOOK_URL=

# Anthropic API key for narrative generation
WATCHTOWER_ANTHROPIC_API_KEY=

# Warden (autonomous threat intelligence loop)
WATCHTOWER_WARDEN_ENABLED=true
WATCHTOWER_WARDEN_MAX_ITERATIONS=10
WATCHTOWER_WARDEN_MAX_DURATION_HOURS=24
WATCHTOWER_WARDEN_INTERVAL_SECONDS=300
